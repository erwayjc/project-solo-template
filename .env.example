# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Connection string for setup migrations (Settings > Database > Connection String > Transaction Pooler)
DATABASE_URL=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: Stripe Connect OAuth
# Requires creating a Stripe Connect platform application at:
# https://dashboard.stripe.com/settings/connect
# Leave blank to use manual API key setup instead.
STRIPE_CLIENT_ID=

# Resend
RESEND_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Buffer (optional)
BUFFER_ACCESS_TOKEN=
# Comma-separated Buffer profile IDs for content publishing
BUFFER_PROFILE_IDS=

# Cron job authentication
# Shared secret for Supabase pg_cron -> Next.js cron route authentication. Generate a random string.
CRON_SECRET=

# Auto-detected
NEXT_PUBLIC_SITE_URL=

# Internal (auto-generated during setup)
# ENCRYPTION_KEY=

# MCP Server Credentials (used by .mcp.json)
# Generate at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
